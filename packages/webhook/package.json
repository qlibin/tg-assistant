{
  "name": "@tg-assistant/webhook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "package:lambda": "npm run build && node ../../scripts/bundle-lambda.js webhook"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.750.0",
    "@qlibin/tg-assistant-contracts": "^1.1.0",
    "@tg-assistant/common": "*"
  }
}
