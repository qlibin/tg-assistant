{
  "name": "tg-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript project configured for Junie Agent in IntelliJ IDEA",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint packages/",
    "lint:fix": "eslint packages/ --fix",
    "format": "prettier --write 'packages/*/src/**' 'packages/*/tests/**'",
    "format:check": "prettier --check 'packages/*/src/**' 'packages/*/tests/**'",
    "type-check": "tsc --build",
    "audit": "npm audit --audit-level moderate",
    "prepare": "husky install",
    "pre-commit": "lint-staged",
    "validate": "npm run build && npm run lint && npm run format:check && npm run type-check && npm run test",
    "package:lambda": "npm run build && node scripts/bundle-lambda.js webhook",
    "package:lambda:webhook": "npm run build && node scripts/bundle-lambda.js webhook",
    "package:lambda:feedback": "npm run build && node scripts/bundle-lambda.js feedback"
  },
  "keywords": [
    "typescript",
    "junie-agent",
    "intellij"
  ],
  "author": "Development Team",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run test:coverage"
    }
  },
  "lint-staged": {
    "packages/**/*.ts": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ]
  }
}
